# Q-SEED 환경 변수 예시
# 사용법: cp .env.example .env

# --- 주식 파이프라인 (접두사: QSEED_STOCK_) ---
# QSEED_STOCK_BASE_DIR=./data
# QSEED_STOCK_MAX_STOCKS=1000
# QSEED_STOCK_CHUNK_SIZE=100
# QSEED_STOCK_DOWNLOAD_PERIOD=max
# QSEED_STOCK_SLEEP_INTERVAL=5.0

# --- GCS 업로드 (접두사: QSEED_GCS_) ---
# QSEED_GCS_BUCKET_NAME=
# QSEED_GCS_TICKER_BLOB_PREFIX=kor_ticker

# --- dbt ---
DBT_PROFILES_DIR=.

# --- Python import path (웹 서버 등 qseed.* 모듈용) ---
PYTHONPATH=src
