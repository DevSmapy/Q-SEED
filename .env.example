# Copy to .env and adjust for your machine. .env is gitignored.
# QSEED_STOCK_BASE_DIR=./data
# QSEED_STOCK_BASE_DIR=/path/to/your/Q-SEED/data

QSEED_STOCK_BASE_DIR=./data
QSEED_STOCK_MAX_STOCKS=1000
QSEED_STOCK_CHUNK_SIZE=100

# GCS upload (optional)
# QSEED_GCS_BUCKET_NAME=

# dbt
DBT_PROFILES_DIR=.

# Python import path (qseed.* modules such as web server)
PYTHONPATH=src
